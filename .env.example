# At least one provider key is required for LLM features (Naive LLM and RAG modes).
# Retrieval Only mode works without any key.

# Server settings
DEV_MODE="false"  # Set to true to enable hot reload (python server.py)

# Gemini (Google) — https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# Claude (Anthropic) — https://console.anthropic.com/
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# ChatGPT (OpenAI) — https://platform.openai.com/
OPENAI_API_KEY="your_openai_api_key_here"
